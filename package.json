{
  "name": "reel-analyzer",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "test": "cd server && npm test",
    "test:smoke": "node scripts/smoke-analyze.mjs",
    "test:comprehensive": "node scripts/test-comprehensive.mjs",
    "test:quality": "node scripts/test-site-quality.mjs",
    "test:supabase": "node scripts/check-supabase.mjs",
    "test:free-usage": "node scripts/test-free-usage.mjs",
    "test:all": "npm test && npm run build && npm run test:quality && npm run test:smoke && npm run test:comprehensive",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "postinstall": "npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@tobyg74/tiktok-api-dl": "^1.3.7"
  }
}
